#  Creative Loop â€” Environment Variables
#  Copy to .env and fill in all PREENCHER_* values before starting.
#  NEVER commit real secrets to the repository.
#
#  Quick start (local, no Docker):
#    python scripts/gen_keys.py   â†’ paste SECRET_KEY + ENCRYPTION_KEY below
#    Keep DATABASE_DRIVER=sqlite for local dev (no Postgres required)
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# â”€â”€ Application â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
APP_BASE_URL=http://localhost:8000
APP_ENV=development

# Generate with: python scripts/gen_keys.py
SECRET_KEY=PREENCHER_SECRET_KEY_32_BYTES_HEX
ENCRYPTION_KEY=PREENCHER_FERNET_KEY_BASE64_44_CHARS

# â”€â”€ Database â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# SQLite (default for local dev â€” no Postgres required)
DATABASE_DRIVER=sqlite
DATABASE_URL=sqlite+aiosqlite:///./creative_loop.db

# PostgreSQL (Docker Compose / staging / production)
# DATABASE_DRIVER=postgres
# DATABASE_URL=postgresql+asyncpg://creative:creative@localhost:5432/creative_loop

# â”€â”€ Redis â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Required only if running Celery worker/beat.
# For local dev without Redis: workers simply won't start (API is unaffected).
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# â”€â”€ Anthropic â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
ANTHROPIC_API_KEY=PREENCHER_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6
# "mock" (default â€” no API calls, no cost) | "real"
ANTHROPIC_PROVIDER=mock
# Tuning (optional â€” built-in defaults shown)
ANTHROPIC_TIMEOUT_S=60.0
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_MAX_IMAGE_MB=5.0
ANTHROPIC_MAX_TOKENS=2048
ANTHROPIC_TEMPERATURE=0.3
# Override pricing in USD/MTok (leave blank to use built-in table)
ANTHROPIC_PRICE_INPUT_PER_MTOK=15.0
ANTHROPIC_PRICE_OUTPUT_PER_MTOK=75.0

# â”€â”€ OpenAI â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
OPENAI_API_KEY=PREENCHER_OPENAI_API_KEY
OPENAI_IMAGE_MODEL=gpt-image-2
# "mock" (default â€” generates Pillow PNG, no cost) | "openai"
IMAGE_PROVIDER=mock
OPENAI_TIMEOUT_S=90.0
OPENAI_MAX_RETRIES=3
OPENAI_IMAGE_QUALITY=standard
IMAGE_MAX_VARIATIONS=4

# â”€â”€ Meta Marketing API â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
META_APP_ID=PREENCHER_META_APP_ID
META_APP_SECRET=PREENCHER_META_APP_SECRET
META_ACCESS_TOKEN=PREENCHER_META_ACCESS_TOKEN
META_GRAPH_API_VERSION=v21.0
META_AD_ACCOUNT_ID=PREENCHER_META_AD_ACCOUNT_ID
META_BUSINESS_ID=PREENCHER_META_BUSINESS_ID
META_PAGE_ID=PREENCHER_META_PAGE_ID
META_INSTAGRAM_ACTOR_ID=PREENCHER_META_INSTAGRAM_ACTOR_ID
META_PIXEL_ID=PREENCHER_META_PIXEL_ID
# "mock" (default) | "real"
META_PROVIDER=mock
# Phase 2 tuning
META_PAGE_LIMIT=200
META_MAX_RETRIES=5
META_RATE_LIMIT_THRESHOLD=85
META_SYNC_INCREMENTAL_DAYS=30
META_SYNC_HISTORY_DATE_START=2024-01-01

# â”€â”€ Storage â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage
SIGNED_URL_TTL_SECONDS=600
# S3 (only needed when STORAGE_BACKEND=s3)
S3_ENDPOINT=PREENCHER_S3_ENDPOINT
S3_BUCKET=PREENCHER_S3_BUCKET
S3_ACCESS_KEY=PREENCHER_S3_ACCESS_KEY
S3_SECRET_KEY=PREENCHER_S3_SECRET_KEY
S3_REGION=auto

# â”€â”€ Quality / Policy gates â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
QUALITY_CV_ENABLED=true
QUALITY_AI_ENABLED=false
ALLOW_BLOCKED_OVERRIDE=false
CREATIVE_SIMILARITY_THRESHOLD=6
CREATIVE_MAX_FILE_MB=15.0

# â”€â”€ Safety Guards (CRITICAL â€” do not change unless you know what you are doing) â”€
DRY_RUN=true
META_WRITE_ENABLED=false
REQUIRE_HUMAN_APPROVAL=true
MAX_DAILY_NEW_ADS=3
MAX_DAILY_SPEND=1000.0
MAX_EXPERIMENT_BUDGET=500.0
MAX_AUTOMATIC_BUDGET_INCREASE_PERCENT=0

# â”€â”€ Phase 5 â€” DRY_RUN publish â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
PUBLICATION_IDEMPOTENCY_TTL_HOURS=24

# â”€â”€ Phase 6 â€” Real Meta publish (all off by default) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Master write switch â€” BOTH DRY_RUN=false AND META_WRITE_ENABLED=true required.
# Never enable in development or staging without explicit sign-off.
META_WRITE_MAX_RETRIES=3
META_WRITE_TIMEOUT_S=60.0
META_REQUIRE_ELEVATED_FOR_ACTIVATION=true
META_ACTIVATION_REQUIRE_CONFIRMATION=true
META_LIVE_TEST_ENABLED=false
CREDENTIAL_ROTATION_WARN_DAYS=30

# â”€â”€ Phase 7 â€” Experiment engine â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
EXP_DEFAULT_MIN_SPEND=50.0
EXP_DEFAULT_MIN_IMPRESSIONS=1000
EXP_DEFAULT_MIN_CLICKS=50
EXP_DEFAULT_MIN_CONVERSIONS=0
EXP_DEFAULT_MIN_DAYS=3
EXP_DEFAULT_MIN_DIFFERENCE=0.10
EXP_DEFAULT_MIN_CONFIDENCE=0.80
EXP_DEFAULT_MAX_FREQUENCY=4.0
EXP_DEFAULT_MATURATION_WINDOW_DAYS=3
EXP_RETRIEVAL_MAX_RESULTS=10
EXP_MAX_VARIATION_DEPTH=3
EXP_MAX_LEARNING_REUSE=3
# "mock" (deterministic SHA256 embeddings) | "real" (external embedding API)
EMBEDDING_PROVIDER=mock
ANOMALOUS_SPEND_MULTIPLIER=3.0

# â”€â”€ Reports (Celery Beat) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
DAILY_REPORT_HOUR=8
WEEKLY_REPORT_DAY=0

# â”€â”€ Localisation â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
DEFAULT_CURRENCY=BRL
DEFAULT_TIMEZONE=America/Sao_Paulo

# â”€â”€ Auth â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# â”€â”€ CORS (comma-separated origins) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
CORS_ORIGINS=http://localhost:3000
